# SkillPath Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# SUPABASE (Optional - App works without it)
# ===========================================
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anonymous key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase service role key (NEVER expose to client)
# Only used in server-side code for admin operations
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# GEMINI AI (Optional - App uses fallback without it)
# ===========================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# ===========================================
# GITHUB (Optional - for unauthenticated API access)
# ===========================================
# Generate a token at: https://github.com/settings/tokens
# Required scopes: none needed for public repo analysis
GITHUB_TOKEN=

# ===========================================
# ADZUNA (Optional - Additional job source)
# ===========================================
# Get your API keys from: https://www.adzuna.com/developers
# Only needed if you want to include Adzuna job listings
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ===========================================
# CRON SECURITY (Required for production cron jobs)
# ===========================================
# Generate a secure secret: openssl rand -base64 32
# Used to protect the /api/cron/sync-jobs endpoint
CRON_SECRET=

# ===========================================
# APP CONFIGURATION
# ===========================================
# Your deployed app URL (used for redirects and OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000